# ============================================================
# Bedrock Core — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# --- Core ---
BEDROCK_ENV=development          # development | staging | production
BEDROCK_DEBUG=true
BEDROCK_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
BEDROCK_LOG_FORMAT=json           # json | text

# --- Licensing ---
BEDROCK_TIER=developer           # developer | starter | business | enterprise
BEDROCK_DEV_MODE=true            # true = localhost only, self-signed certs
BEDROCK_LICENSE_KEY=             # Production license key (leave empty for dev)
BEDROCK_LICENSE_KEY_PATH=/etc/bedrock/license.key

# --- Encryption ---
BEDROCK_MASTER_KEY=              # 32-byte hex key (auto-generated if empty in dev)
BEDROCK_MASTER_KEY_FILE=         # Path to key file (overrides BEDROCK_MASTER_KEY)

# --- Identity ---
BEDROCK_CERT_CA_CERT_PATH=/etc/bedrock/ca-cert.pem
BEDROCK_CERT_CA_KEY_PATH=/etc/bedrock/ca-key.pem
BEDROCK_CERT_DEFAULT_TTL_HOURS=24

# --- Data Separation ---
BEDROCK_SILO_STRICT_MODE=true
BEDROCK_CONSENT_DEFAULT_TTL_SECONDS=3600
BEDROCK_CONSENT_REQUIRE_REASON=true

# --- Audit ---
BEDROCK_AUDIT_CHAIN_PATH=/var/lib/bedrock/audit
BEDROCK_AUDIT_RETENTION_YEARS=6
BEDROCK_AUDIT_EXPORT_FORMAT=jsonl

# --- Access Control ---
BEDROCK_MFA_REQUIRED=true
BEDROCK_SESSION_TTL_SECONDS=3600
BEDROCK_RATE_LIMIT_RPM=60

# --- Mesh ---
BEDROCK_MESH_HEARTBEAT_TIMEOUT_SECONDS=30
BEDROCK_MESH_TOPOLOGY=partial_mesh

# --- Telemetry (DISABLED by default — no phone-home) ---
BEDROCK_PHONE_HOME_ENABLED=false
BEDROCK_PHONE_HOME_URL=